{
  "name": "softdmx",
  "version": "0.0.1",
  "description": "Soft DMX",
  "productName": "SoftDMX",
  "author": "booploops <49113086+booploops@users.noreply.github.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/**/*.test.ts' 'test/e2e/**/*.mjs' test/e2e-smoke.mjs",
    "test:unit": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/*.test.ts' 'test/unit/**/*.test.ts' 'test/helpers/**/*.test.ts' 'test/fixtures/**/*.test.ts' 'test/fuzz/**/*.test.ts'",
    "test:property": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/property/**/*.test.ts'",
    "test:integration": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/integration/**/*.test.ts'",
    "test:e2e": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/e2e/**/*.mjs' test/e2e-smoke.mjs",
    "test:fuzz": "node test/fuzz/run-fuzz.mjs",
    "test:fuzz:ci": "FUZZ_CI=1 node test/fuzz/run-fuzz.mjs",
    "test:playwright": "playwright test",
    "test:playwright:electron": "SOFTDMX_E2E=1 playwright test",
    "test:coverage": "NODE_V8_COVERAGE=./coverage node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --experimental-test-coverage --test 'test/**/*.test.ts' 'test/e2e/**/*.mjs' test/e2e-smoke.mjs",
    "test:all": "yarn test",
    "output-node": "quasar dev -m electron -- --output-node",
    "dev": "quasar dev -m electron",
    "build": "quasar build -m electron",
    "build:spa": "quasar build",
    "cli": "node scripts/softdmx-cli.mjs",
    "postinstall": "node scripts/patch-abletonlink.mjs && node scripts/rebuild-native.mjs && quasar prepare"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@msgpack/msgpack": "^3.1.3",
    "@napolab/texture-bridge": "0.13.1",
    "@quasar/extras": "^1.18.0",
    "@vueuse/core": "^13.9.0",
    "abletonlink": "^0.2.0-beta.0",
    "alien-signals": "^2.0.8",
    "fast-xml-parser": "^5.9.3",
    "fastify": "^5.8.5",
    "fflate": "^0.8.3",
    "idb-keyval": "^6.2.5",
    "linear-timecode": "^0.1.0",
    "lodash-es": "^4.18.1",
    "node-osc": "^11.5.0",
    "pinia": "^3.0.4",
    "quasar": "^2.20.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@electron/rebuild": "^4.0.4",
    "@intlify/unplugin-vue-i18n": "^4.0.0",
    "@jazzer.js/core": "^4.0.0",
    "@playwright/test": "^1.61.0",
    "@quasar/app-vite": "^2.6.2",
    "@types/lodash-es": "^4",
    "@types/node": "^22.20.0",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.5",
    "fast-check": "^4.8.0",
    "typescript": "~5.8.3",
    "unplugin-auto-import": "^19.3.0"
  },
  "engines": {
    "node": "22.23.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 4.17.0"
  },
  "packageManager": "yarn@4.17.0",
  "optionalDependencies": {
    "@napolab/texture-bridge-darwin-arm64": "0.13.1",
    "@napolab/texture-bridge-darwin-x64": "0.13.1",
    "@napolab/texture-bridge-win32-x64-msvc": "0.13.1"
  }
}
