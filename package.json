{
  "name": "softdmx-monorepo",
  "private": true,
  "packageManager": "yarn@4.17.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "yarn workspace @softdmx/frontend dev",
    "dev:electron": "yarn workspace @softdmx/client dev",
    "dev": "concurrently \"yarn dev:frontend\" \"yarn dev:electron\"",
    "build:frontend": "yarn workspace @softdmx/frontend build",
    "build:electron": "yarn workspace @softdmx/client build",
    "build": "yarn build:frontend && yarn build:electron",
    "test": "yarn workspace @softdmx/frontend test",
    "postinstall": "yarn workspace @softdmx/client postinstall:client && yarn workspace @softdmx/frontend prepare:quasar"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
