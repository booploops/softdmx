{
  "name": "@softdmx/frontend",
  "version": "0.0.1",
  "description": "Soft DMX Frontend",
  "productName": "SoftDMX",
  "author": "booploops <49113086+booploops@users.noreply.github.com>",
  "type": "module",
  "license": "MPL-2.0",
  "scripts": {
    "test": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/**/*.test.ts' 'test/e2e/**/*.mjs' test/e2e-smoke.mjs",
    "test:unit": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/*.test.ts' 'test/unit/**/*.test.ts' 'test/helpers/**/*.test.ts' 'test/fixtures/**/*.test.ts' 'test/fuzz/**/*.test.ts'",
    "test:property": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/property/**/*.test.ts'",
    "test:integration": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/integration/**/*.test.ts'",
    "test:e2e": "node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --test 'test/e2e/**/*.mjs' test/e2e-smoke.mjs",
    "test:fuzz": "node test/fuzz/run-fuzz.mjs",
    "test:fuzz:ci": "FUZZ_CI=1 node test/fuzz/run-fuzz.mjs",
    "test:playwright": "playwright test",
    "test:playwright:electron": "SOFTDMX_E2E=1 playwright test",
    "test:coverage": "NODE_V8_COVERAGE=./coverage node --import ./test/helpers/register-src-alias.mjs --experimental-strip-types --experimental-test-coverage --test 'test/**/*.test.ts' 'test/e2e/**/*.mjs' test/e2e-smoke.mjs",
    "test:all": "yarn test",
    "dev": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@msgpack/msgpack": "^3.1.3",
    "@quasar/extras": "^2.0.1",
    "@softdmx/engine": "workspace:*",
    "@softdmx/wasm": "workspace:*",
    "@vueuse/core": "^14.3.0",
    "alien-signals": "^3.2.1",
    "fflate": "^0.8.3",
    "idb-keyval": "^6.2.5",
    "linear-timecode": "^0.1.0",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "quasar": "^2.20.1",
    "socket.io-client": "^4.8.3",
    "vue": "3.6.0-beta.16",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@jazzer.js/core": "^4.0.0",
    "@playwright/test": "^1.61.0",
    "@quasar/vite-plugin": "^1.12.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.15.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.5.0",
    "fast-check": "^4.8.0",
    "fastify": "^5.8.5",
    "postcss": "^8.4.49",
    "sass": "^1.81.0",
    "socket.io": "^4.8.3",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.1.0",
    "vite-plugin-vue-devtools": "^8.1.3"
  }
}
