{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "noImplicitOverride": false,
    "paths": {
      "@softdmx/engine": ["../engine/src/index.ts"],
      "@softdmx/engine/*": ["../engine/src/*"],
      "@softdmx/wasm": ["../wasm/src/index.ts"],
      "@softdmx/wasm/*": ["../wasm/src/*"],
      "src/*": ["./src/*"],
      "src-electron/*": ["../client/src-electron/*"],
      "@": ["./src"],
      "@/*": ["./src/*"],
      "layouts/*": ["./src/layouts/*"],
      "pages/*": ["./src/pages/*"],
      "components/*": ["./src/components/*"],
      "assets/*": ["./src/assets/*"],
      "boot/*": ["./src/boot/*"],
      "electron": ["../client/src-electron/node_modules/electron"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "auto-imports.d.ts"]
}