{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn"],
  "env": {
    "node": true
  },
  "overrides": [
    {
      "files": ["*.ts"],
      "rules": {
        "eslint/no-unused-vars": "off",
        "no-var": "error"
      }
    }
  ]
}
