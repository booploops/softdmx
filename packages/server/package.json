{
  "name": "@softdmx/server",
  "bin": "build/index.js",
  "scripts": {
    "dev": "tsx watch ./src/main.ts",
    "lint": "oxlint --ignore-pattern build .",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "build:js": "tsx ./scripts/build.ts",
    "build:pkg": "pkg . --sea",
    "build:exe": "yarn build:js && yarn build:pkg"
  },
  "type": "module",
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "hono": "^4.12.27",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.72.0",
    "rolldown": "^1.1.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "alien-signals": "^3.2.1",
    "bonjour-service": "^1.4.2"
  }
}
