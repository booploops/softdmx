{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@softdmx/engine": ["../engine/src/index.ts"],
      "@softdmx/engine/*": ["../engine/src/*"],
      "@softdmx/wasm": ["../wasm/src/index.ts"],
      "@softdmx/wasm/*": ["../wasm/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.mjs"]
}
