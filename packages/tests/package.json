{
  "name": "@softdmx/tests",
  "version": "0.0.1",
  "description": "Soft DMX Tests Package",
  "type": "module",
  "license": "MPL-2.0",
  "scripts": {
    "test": "node --import ./src/helpers/register-src-alias.mjs --experimental-strip-types --test 'src/**/*.test.ts' 'src/e2e/**/*.mjs' src/e2e-smoke.mjs",
    "test:unit": "node --import ./src/helpers/register-src-alias.mjs --experimental-strip-types --test 'src/*.test.ts' 'src/unit/**/*.test.ts' 'src/helpers/**/*.test.ts' 'src/fixtures/**/*.test.ts' 'src/fuzz/**/*.test.ts'",
    "test:property": "node --import ./src/helpers/register-src-alias.mjs --experimental-strip-types --test 'src/property/**/*.test.ts'",
    "test:integration": "node --import ./src/helpers/register-src-alias.mjs --experimental-strip-types --test 'src/integration/**/*.test.ts'",
    "test:e2e": "node --import ./src/helpers/register-src-alias.mjs --experimental-strip-types --test 'src/e2e/**/*.mjs' src/e2e-smoke.mjs",
    "test:fuzz": "node src/fuzz/run-fuzz.mjs",
    "test:fuzz:ci": "FUZZ_CI=1 node src/fuzz/run-fuzz.mjs",
    "test:playwright": "playwright test",
    "test:playwright:electron": "SOFTDMX_E2E=1 playwright test",
    "test:coverage": "NODE_V8_COVERAGE=./coverage node --import ./src/helpers/register-src-alias.mjs --experimental-strip-types --experimental-test-coverage --test 'src/**/*.test.ts' 'src/e2e/**/*.mjs' src/e2e-smoke.mjs",
    "test:all": "yarn test"
  },
  "dependencies": {
    "@softdmx/engine": "workspace:*",
    "@softdmx/frontend": "workspace:*",
    "@softdmx/wasm": "workspace:*",
    "lodash-es": "^4.18.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@jazzer.js/core": "^4.0.0",
    "@playwright/test": "^1.61.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.15.0",
    "fast-check": "^4.8.0",
    "fastify": "^5.8.5",
    "socket.io": "^4.8.3",
    "typescript": "~6.0.3"
  }
}
