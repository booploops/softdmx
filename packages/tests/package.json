{
  "name": "@softdmx/tests",
  "version": "0.0.1",
  "description": "Soft DMX Tests Package",
  "type": "module",
  "license": "MPL-2.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/*.test.ts src/unit src/helpers src/fixtures src/fuzz",
    "test:property": "vitest run src/property",
    "test:integration": "vitest run src/integration",
    "test:e2e": "vitest run src/e2e src/e2e-smoke.mjs",
    "test:fuzz": "node src/fuzz/run-fuzz.mjs",
    "test:fuzz:ci": "FUZZ_CI=1 node src/fuzz/run-fuzz.mjs",
    "test:playwright": "playwright test",
    "test:playwright:electron": "SOFTDMX_E2E=1 playwright test",
    "test:runtime-baseline": "node src/perf/runtime-baseline.mjs",
    "test:runtime-compare": "node src/perf/compare-runtime-baseline.mjs",
    "test:coverage": "vitest run --coverage 'src/**/*.test.ts' 'src/e2e/**/*.mjs' 'src/e2e-smoke.mjs'",
    "test:all": "yarn test"
  },
  "dependencies": {
    "@softdmx/engine": "workspace:*",
    "@softdmx/frontend": "workspace:*",
    "@softdmx/wasm": "workspace:*",
    "lodash-es": "^4.18.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@jazzer.js/core": "^4.0.0",
    "@playwright/test": "^1.61.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.1.9",
    "fast-check": "^4.8.0",
    "fastify": "^5.8.5",
    "socket.io": "^4.8.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
